{%- if data.images.size > 0 -%}
  <section class="dw-section">
    <div class="dw-container">
      {%- if data.title != blank -%}
        <h2 class="dw-section-title">{{ data.title }}</h2>
      {%- endif -%}
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
        {%- for image in data.images -%}
          <div style="aspect-ratio:1/1;overflow:hidden;border-radius:var(--store-radius);">
            <img src="{{ image.url }}" alt="{{ image.caption | default: '' | escape }}" width="600" height="600" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}
