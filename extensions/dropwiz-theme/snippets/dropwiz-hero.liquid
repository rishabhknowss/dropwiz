{%- if data == blank -%}
  {%- comment -%}no hero data{%- endcomment -%}
{%- else -%}
  {%- assign variant = data.variant | default: 'split' -%}

  {%- case variant -%}
    {%- when 'centered' -%}
      <section class="dw-section">
        <div class="dw-container" style="display:flex;flex-direction:column;align-items:center;text-align:center;max-width:920px;">
          {%- if data.urgencyBadge != blank -%}
            <div style="margin-bottom:20px;"><span class="dw-badge">{{ data.urgencyBadge }}</span></div>
          {%- endif -%}
          <h1 class="dw-hero-headline" style="text-align:center;">{{ data.headline }}</h1>
          <p class="dw-hero-sub" style="margin-left:auto;margin-right:auto;max-width:620px;">{{ data.subheadline }}</p>
          <div class="dw-hero-cta-row" style="justify-content:center;">
            <a href="#dw-product" class="dw-btn-primary">{{ data.primaryCta }}</a>
            {%- if data.secondaryCta != blank -%}
              <a href="#dw-faq" class="dw-btn-secondary">{{ data.secondaryCta }}</a>
            {%- endif -%}
          </div>
          {%- if data.socialProof != blank -%}
            <div style="margin-top:20px;font-size:12.5px;opacity:0.6;">{{ data.socialProof }}</div>
          {%- endif -%}
          {%- if data.imageUrl != blank -%}
            <div style="margin-top:36px;width:100%;max-width:860px;">
              <div class="dw-hero-image" style="aspect-ratio:16/10;">
                <img src="{{ data.imageUrl }}" alt="{{ data.headline | escape }}" width="1600" height="1200" loading="lazy" />
              </div>
            </div>
          {%- endif -%}
        </div>
      </section>

    {%- when 'full-bleed' -%}
      <section style="position:relative;height:88svh;min-height:520px;overflow:hidden;">
        <div style="position:absolute;inset:0;">
          {%- if data.imageUrl != blank -%}
            <img src="{{ data.imageUrl }}" alt="" width="1920" height="1080" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
          {%- else -%}
            <div class="dw-hero-image-fallback" style="height:100%;"></div>
          {%- endif -%}
        </div>
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.27) 0%, rgba(0,0,0,0.45) 60%, rgba(0,0,0,0.54) 100%);"></div>
        <div style="position:relative;z-index:10;display:flex;flex-direction:column;height:100%;padding:24px;color:#fff;">
          <div style="margin-top:auto;max-width:820px;">
            {%- if data.urgencyBadge != blank -%}
              <div style="display:inline-flex;align-items:center;border-radius:999px;background:rgba(255,255,255,0.15);padding:4px 12px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;backdrop-filter:blur(8px);margin-bottom:16px;">{{ data.urgencyBadge }}</div>
            {%- endif -%}
            <h1 class="dw-hero-headline" style="color:#fff;">{{ data.headline }}</h1>
            <p class="dw-hero-sub" style="color:rgba(255,255,255,0.85);">{{ data.subheadline }}</p>
            <div class="dw-hero-cta-row">
              <a href="#dw-product" class="dw-btn-primary">{{ data.primaryCta }}</a>
              {%- if data.secondaryCta != blank -%}
                <a href="#dw-faq" class="dw-btn-secondary" style="border-color:rgba(255,255,255,0.4);color:#fff;">{{ data.secondaryCta }}</a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>

    {%- when 'minimal' -%}
      <section class="dw-section">
        <div class="dw-container">
          {%- if data.urgencyBadge != blank -%}
            <div class="dw-mono" style="margin-bottom:12px;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;opacity:0.6;">{{ data.urgencyBadge }}</div>
          {%- endif -%}
          <div style="display:grid;grid-template-columns:1fr;gap:32px;align-items:end;">
            <h1 class="dw-hero-headline">{{ data.headline }}</h1>
            <div style="display:flex;flex-direction:column;gap:16px;">
              <p class="dw-hero-sub" style="font-size:14.5px;line-height:1.55;">{{ data.subheadline }}</p>
              <div class="dw-hero-cta-row">
                <a href="#dw-product" class="dw-btn-primary">{{ data.primaryCta }}</a>
                {%- if data.secondaryCta != blank -%}
                  <a href="#dw-faq" class="dw-btn-secondary">{{ data.secondaryCta }}</a>
                {%- endif -%}
              </div>
              {%- if data.socialProof != blank -%}
                <div style="font-size:12px;opacity:0.55;">{{ data.socialProof }}</div>
              {%- endif -%}
            </div>
          </div>
          {%- if data.imageUrl != blank -%}
            <div style="margin-top:32px;">
              <div class="dw-hero-image" style="aspect-ratio:16/10;">
                <img src="{{ data.imageUrl }}" alt="{{ data.headline | escape }}" width="1600" height="1200" loading="lazy" />
              </div>
            </div>
          {%- endif -%}
        </div>
      </section>

    {%- when 'magazine' -%}
      <section class="dw-section">
        <div class="dw-container">
          <div class="dw-mono" style="display:flex;justify-content:space-between;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;opacity:0.6;margin-bottom:24px;">
            <span>{{ data.urgencyBadge | default: 'Volume 01' }}</span>
            <span>{{ data.brandName | default: 'Editorial' }}</span>
          </div>
          <div class="dw-hero-image" style="aspect-ratio:16/9;">
            {%- if data.imageUrl != blank -%}
              <img src="{{ data.imageUrl }}" alt="{{ data.headline | escape }}" width="1600" height="1200" loading="lazy" />
            {%- else -%}
              <div class="dw-hero-image-fallback"></div>
            {%- endif -%}
          </div>
          <div style="display:grid;grid-template-columns:1fr;gap:32px;margin-top:32px;">
            <h1 class="dw-hero-headline" style="font-family:var(--store-font-display);letter-spacing:-0.04em;">{{ data.headline }}</h1>
            <div style="border-top:1px solid rgba(10,10,10,0.15);padding-top:16px;font-size:14.5px;line-height:1.55;opacity:0.75;">
              <p>{{ data.subheadline }}</p>
              <div class="dw-hero-cta-row">
                <a href="#dw-product" class="dw-btn-primary">{{ data.primaryCta }}</a>
                {%- if data.secondaryCta != blank -%}
                  <a href="#dw-faq" class="dw-btn-secondary">{{ data.secondaryCta }}</a>
                {%- endif -%}
              </div>
              {%- if data.socialProof != blank -%}
                <div style="margin-top:16px;font-size:12px;opacity:0.55;">{{ data.socialProof }}</div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>

    {%- else -%}
      {%- comment -%}split (default){%- endcomment -%}
      <section class="dw-section">
        <div class="dw-container">
          <div class="dw-hero-split">
            <div>
              {%- if data.urgencyBadge != blank -%}
                <div style="margin-bottom:20px;"><span class="dw-badge">{{ data.urgencyBadge }}</span></div>
              {%- endif -%}
              <h1 class="dw-hero-headline">{{ data.headline }}</h1>
              <p class="dw-hero-sub">{{ data.subheadline }}</p>
              <div class="dw-hero-cta-row">
                <a href="#dw-product" class="dw-btn-primary">{{ data.primaryCta }}</a>
                {%- if data.secondaryCta != blank -%}
                  <a href="#dw-faq" class="dw-btn-secondary">{{ data.secondaryCta }}</a>
                {%- endif -%}
              </div>
              {%- if data.socialProof != blank -%}
                <div style="margin-top:20px;font-size:12.5px;opacity:0.6;">{{ data.socialProof }}</div>
              {%- endif -%}
            </div>
            <div class="dw-hero-image">
              {%- if data.imageUrl != blank -%}
                <img src="{{ data.imageUrl }}" alt="{{ data.headline | escape }}" width="1600" height="1200" loading="lazy" />
              {%- else -%}
                <div class="dw-hero-image-fallback"></div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>
  {%- endcase -%}
{%- endif -%}
