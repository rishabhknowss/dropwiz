{%- if data.storeName != blank -%}
  <footer class="dw-footer-section">
    <div class="dw-container">
      <div class="dw-footer-main">
        <div class="dw-footer-brand">
          <div class="dw-footer-logo">{{ data.storeName }}</div>
          {%- if data.tagline != blank -%}
            <p class="dw-footer-tagline">{{ data.tagline }}</p>
          {%- endif -%}
        </div>

        <div class="dw-footer-links">
          <div class="dw-footer-col">
            <div class="dw-footer-heading">Shop</div>
            <ul>
              <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
              <li><a href="{{ routes.collections_url }}/best-sellers">Best Sellers</a></li>
              <li><a href="{{ routes.collections_url }}/new-arrivals">New Arrivals</a></li>
            </ul>
          </div>
          <div class="dw-footer-col">
            <div class="dw-footer-heading">Support</div>
            <ul>
              <li><a href="/pages/contact">Contact Us</a></li>
              <li><a href="/pages/shipping">Shipping Info</a></li>
              <li><a href="/pages/returns">Returns & Refunds</a></li>
              <li><a href="/pages/faq">FAQ</a></li>
            </ul>
          </div>
          <div class="dw-footer-col">
            <div class="dw-footer-heading">Company</div>
            <ul>
              <li><a href="/pages/about">About Us</a></li>
              <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
              <li><a href="/policies/terms-of-service">Terms of Service</a></li>
            </ul>
          </div>
        </div>
      </div>

      <div class="dw-footer-bottom">
        <div class="dw-footer-payment">
          <span class="dw-payment-label">We accept</span>
          <div class="dw-payment-icons">
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/amex.syvJPBCK.svg" alt="American Express" class="dw-payment-icon" width="38" height="24" />
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/visa.6nIY1mVH.svg" alt="Visa" class="dw-payment-icon" width="38" height="24" />
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/mastercard.CnRwv58k.svg" alt="Mastercard" class="dw-payment-icon" width="38" height="24" />
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/paypal.C5TQ8Gfp.svg" alt="PayPal" class="dw-payment-icon" width="38" height="24" />
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/shopify_pay.C3caTzSH.svg" alt="Shop Pay" class="dw-payment-icon" width="38" height="24" />
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/google_pay.CNVoKfst.svg" alt="Google Pay" class="dw-payment-icon" width="38" height="24" />
            <img src="https://cdn.shopify.com/shopifycloud/checkout-web/assets/c1.en/assets/apple_pay.Dz8gKPPZ.svg" alt="Apple Pay" class="dw-payment-icon" width="38" height="24" />
          </div>
        </div>
        <div class="dw-footer-copyright">
          © {{ 'now' | date: '%Y' }} {{ data.storeName }}. All Rights Reserved.
        </div>
      </div>
    </div>
  </footer>

  <style>
    .dw-footer-section {
      background: var(--dw-bg, #fafaf7);
      border-top: 1px solid var(--dw-border, rgba(0,0,0,0.08));
      padding: 60px 0 30px;
      margin-top: 60px;
    }
    .dw-footer-main {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 48px;
      padding-bottom: 40px;
      border-bottom: 1px solid var(--dw-border, rgba(0,0,0,0.08));
    }
    @media (max-width: 768px) {
      .dw-footer-main { grid-template-columns: 1fr; gap: 32px; }
    }
    .dw-footer-logo {
      font-family: var(--dw-font-display, serif);
      font-size: 24px;
      font-weight: 500;
      letter-spacing: -0.02em;
    }
    .dw-footer-tagline {
      margin-top: 12px;
      font-size: 14px;
      opacity: 0.7;
      max-width: 280px;
      line-height: 1.5;
    }
    .dw-footer-links {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    @media (max-width: 640px) {
      .dw-footer-links { grid-template-columns: repeat(2, 1fr); }
    }
    .dw-footer-heading {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 16px;
      opacity: 0.5;
    }
    .dw-footer-col ul { list-style: none; padding: 0; margin: 0; }
    .dw-footer-col li { margin-bottom: 10px; }
    .dw-footer-col a {
      font-size: 14px;
      color: inherit;
      text-decoration: none;
      opacity: 0.8;
      transition: opacity 0.2s;
    }
    .dw-footer-col a:hover { opacity: 1; }
    .dw-footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 24px;
      flex-wrap: wrap;
      gap: 20px;
    }
    .dw-footer-payment {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .dw-payment-label {
      font-size: 12px;
      opacity: 0.5;
    }
    .dw-payment-icons {
      display: flex;
      gap: 6px;
    }
    .dw-payment-icon {
      height: 28px;
      width: auto;
      border-radius: 4px;
      border: 1px solid var(--dw-border, rgba(0,0,0,0.08));
      background: #fff;
    }
    .dw-footer-copyright {
      font-size: 13px;
      opacity: 0.5;
    }
  </style>
{%- endif -%}
