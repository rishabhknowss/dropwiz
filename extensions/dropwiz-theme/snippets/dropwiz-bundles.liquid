{%- if data.bundles.size > 0 -%}
  {%- assign variant = data.variant | default: 'tiers' -%}
  <section class="dw-section">
    <div class="dw-container">
      <h2 class="dw-section-title">Save more, bundle up</h2>

      {%- case variant -%}
        {%- when 'compact' -%}
          <div style="display:flex;flex-direction:column;gap:8px;max-width:640px;margin:0 auto;">
            {%- for bundle in data.bundles -%}
              <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 20px;border:1px solid {% if bundle.recommended %}var(--store-primary){% else %}rgba(10,10,10,0.1){% endif %};border-radius:var(--store-radius);background:rgba(255,255,255,0.5);">
                <div style="flex:1;">
                  <div style="display:flex;align-items:center;gap:8px;">
                    <span style="font-size:15px;font-weight:600;">{{ bundle.name }}</span>
                    {%- if bundle.badge != blank -%}
                      <span class="dw-badge">{{ bundle.badge }}</span>
                    {%- endif -%}
                  </div>
                  <div style="font-size:12.5px;opacity:0.65;margin-top:2px;">{{ bundle.description }}</div>
                </div>
                <div style="text-align:right;">
                  <div style="font-size:13px;font-weight:600;">{{ bundle.savings }}</div>
                  <a href="#dw-product" style="display:inline-block;margin-top:6px;font-size:11px;font-weight:600;text-decoration:underline;color:var(--store-primary);">Choose →</a>
                </div>
              </div>
            {%- endfor -%}
          </div>

        {%- when 'showcase' -%}
          <div style="max-width:760px;margin:0 auto;">
            {%- for bundle in data.bundles -%}
              {%- if bundle.recommended -%}
                <div style="border:2px solid var(--store-primary);border-radius:var(--store-radius);padding:32px;background:rgba(255,255,255,0.6);text-align:center;">
                  {%- if bundle.badge != blank -%}
                    <div style="margin-bottom:16px;"><span class="dw-badge">{{ bundle.badge }}</span></div>
                  {%- endif -%}
                  <h3 style="font-size:28px;font-weight:600;margin:0 0 8px;">{{ bundle.name }}</h3>
                  <p style="font-size:18px;font-weight:500;opacity:0.8;margin:0 0 16px;">{{ bundle.savings }}</p>
                  <p style="font-size:15px;opacity:0.7;line-height:1.55;max-width:480px;margin:0 auto 24px;">{{ bundle.description }}</p>
                  <a href="#dw-product" class="dw-btn-primary" style="padding:16px 32px;font-size:15px;">Choose this bundle</a>
                </div>
              {%- endif -%}
            {%- endfor -%}
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-top:16px;">
              {%- for bundle in data.bundles -%}
                {%- unless bundle.recommended -%}
                  <div style="border:1px solid rgba(10,10,10,0.1);border-radius:var(--store-radius);padding:16px;text-align:center;">
                    <div style="font-size:14px;font-weight:600;margin-bottom:4px;">{{ bundle.name }}</div>
                    <div style="font-size:12px;opacity:0.7;margin-bottom:12px;">{{ bundle.savings }}</div>
                    <a href="#dw-product" style="font-size:11px;font-weight:600;text-decoration:underline;color:var(--store-primary);">Choose →</a>
                  </div>
                {%- endunless -%}
              {%- endfor -%}
            </div>
          </div>

        {%- else -%}
          {%- comment -%}tiers (default){%- endcomment -%}
          <div class="dw-bundles">
            {%- for bundle in data.bundles -%}
              <div class="dw-bundle{% if bundle.recommended %} is-recommended{% endif %}">
                {%- if bundle.badge != blank -%}
                  <div style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);"><span class="dw-badge">{{ bundle.badge }}</span></div>
                {%- endif -%}
                <h3 class="dw-bundle-name">{{ bundle.name }}</h3>
                <p class="dw-bundle-savings">{{ bundle.savings }}</p>
                <p class="dw-bundle-desc">{{ bundle.description }}</p>
                <a href="#dw-product" class="dw-btn-primary" style="width:100%;justify-content:center;">Choose this bundle</a>
              </div>
            {%- endfor -%}
          </div>
      {%- endcase -%}
    </div>
  </section>
{%- endif -%}
