{%- if data.faqs.size > 0 -%}
  {%- assign variant = data.variant | default: 'accordion' -%}
  <section class="dw-section" id="dw-faq">
    <div class="dw-container">
      <h2 class="dw-section-title">Questions, answered</h2>

      {%- case variant -%}
        {%- when 'two-column' -%}
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;max-width:1000px;margin:0 auto;">
            {%- for faq in data.faqs -%}
              <div>
                <h3 style="font-size:16px;font-weight:600;margin:0 0 8px;line-height:1.35;">{{ faq.question }}</h3>
                <p style="font-size:14px;opacity:0.75;line-height:1.6;margin:0;">{{ faq.answer }}</p>
              </div>
            {%- endfor -%}
          </div>

        {%- when 'cards' -%}
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;max-width:1100px;margin:0 auto;">
            {%- for faq in data.faqs -%}
              <div style="border:1px solid rgba(10,10,10,0.08);border-radius:var(--store-radius);padding:20px;background:rgba(255,255,255,0.5);">
                <h3 style="font-size:15px;font-weight:600;margin:0 0 10px;">{{ faq.question }}</h3>
                <p style="font-size:13.5px;opacity:0.7;line-height:1.55;margin:0;">{{ faq.answer }}</p>
              </div>
            {%- endfor -%}
          </div>

        {%- else -%}
          {%- comment -%}accordion (default){%- endcomment -%}
          <div class="dw-faq" style="max-width:820px;margin:0 auto;">
            {%- for faq in data.faqs -%}
              <details class="dw-faq-item">
                <summary>{{ faq.question }}</summary>
                <p>{{ faq.answer }}</p>
              </details>
            {%- endfor -%}
          </div>
      {%- endcase -%}
    </div>
  </section>
{%- endif -%}
