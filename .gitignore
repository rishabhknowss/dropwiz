# ────────────────────────────────────────────────────────────
# Dropwiz .gitignore
# Anything sensitive, generated, machine-specific, or local-notes
# stays out of the repo. Source code, lockfiles, configs in.
# ────────────────────────────────────────────────────────────

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm/
.pnpm-store/

# ─── Build output (anchored to repo root so we don't shadow real dirs) ──
/.next/
/out/
/build/
/dist/
/.turbo/
/.swc/
*.tsbuildinfo
next-env.d.ts

# ─── Environment / secrets ────────────────────────────────────
# All env files in any dir, regardless of suffix
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ─── Credentials, keys, certs ─────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.der
*.csr
*.p12
*.pfx
*.jks
*.keystore
secrets/
credentials/
.secrets/
service-account*.json
gcp-key*.json
aws-credentials
.aws/
.gcloud/
.shopify-cli-config

# ─── Cloud / deploy artefacts ─────────────────────────────────
.vercel/
.shopify/
.railway/
.wrangler/
.cf/

# ─── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ─── Testing / coverage ───────────────────────────────────────
/coverage/
/.nyc_output/
*.lcov

# ─── IDE / editor ─────────────────────────────────────────────
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store
Thumbs.db
.fleet/
.zed/

# ─── OS junk ──────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ─── Markdown notes (per request — internal docs stay local) ──
*.md
*.mdx
!CLAUDE.md

# ─── TypeScript / tooling ─────────────────────────────────────
*.tsbuildinfo

# ─── Drizzle / DB temp files (migrations stay tracked) ────────
drizzle/_journal.json.bak
drizzle/snapshot-*.bak

# ─── R2 / asset uploads (if accidentally placed here) ─────────
public/uploads/
public/tmp/

# ─── Misc ─────────────────────────────────────────────────────
/.cache/
/.tmp/
/tmp/
*.bak
*.orig
*.rej
